# Environment Variables
#
# Copy to .env and fill in values:
#   cp .devcontainer/.env.example .devcontainer/.env
#
# IMPORTANT: .env is in .gitignore — never commit secrets.
# Codespaces users: add as repository secrets instead.

# --- GitHub (required) ---
# Get token from: https://github.com/settings/tokens
# Required permissions: repo, read:user, workflow
GH_TOKEN=

# --- GitHub Roche account (optional) ---
# PAT (classic) with SSO for corporate GitHub account
# Required permissions: repo, read:user, read:org, workflow
# GH_TOKEN_ROCHE=
# Pipe-separated GitHub orgs routed to Roche token (default: RIS-Navify-Data-Platform)
# GH_ROCHE_ORGS=RIS-Navify-Data-Platform|another-roche-org

# --- SSH (optional) ---
# Base64-encoded SSH private key for Git auth
# Encode with: base64 -w 0 ~/.ssh/id_rsa
# SSH_PRIVATE_KEY=

# --- MCP Servers (optional) ---
# Context7: https://upstash.com/
# CONTEXT7_API_KEY=
# Coolify self-hosted PaaS
# COOLIFY_BASE_URL=
# COOLIFY_ACCESS_TOKEN=
# Google Stitch: https://stitch.withgoogle.com/
# STITCH_API_KEY=

# --- Git Identity (optional) ---
# GIT_USER_NAME=
# GIT_USER_EMAIL=

# --- DevContainer Config (optional) ---
# Set to "true" to clear config on next rebuild
# Useful for troubleshooting plugin issues
# RESET_CLAUDE_CONFIG=
# RESET_GEMINI_CONFIG=
