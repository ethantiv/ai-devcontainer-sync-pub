{
  "name": "AI Agents Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {}
  },
  "onCreateCommand": {
    "setup-claude-dir": "sudo mkdir -p /home/vscode/.claude && sudo chown -R vscode:vscode /home/vscode/.claude"
  },
  "postCreateCommand": "export PATH=\"$HOME/.local/bin:$PATH\" && curl -fsSL https://claude.ai/install.sh | bash && curl -fsSL https://bun.sh/install | bash && chmod +x .devcontainer/setup-env.sh && ./.devcontainer/setup-env.sh",
  "mounts": [
    {
      "source": "claude-config-${devcontainerId}",
      "target": "/home/vscode/.claude",
      "type": "volume"
    },
    {
      "source": "/Users/mirek/Projekty",
      "target": "/home/vscode/projects",
      "type": "bind"
    }
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
  },
  "remoteEnv": {
    "PATH": "/home/vscode/.local/bin:/home/vscode/.bun/bin:${containerEnv:PATH}"
  },
  "runArgs": [
    "--env-file",
    "config/.env",
    "--shm-size=256m"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "workbench.colorTheme": "GitHub Dark Default",
        "terminal.integrated.enablePersistentSessions": false,
        "terminal.integrated.cwd": "${workspaceFolder}",
        "terminal.integrated.gpuAcceleration": "off"
      },
      "extensions": [
        "-AmazonWebServices.aws-toolkit-vscode",
        "anthropic.claude-code",
        "bierner.markdown-mermaid",
        "github.github-vscode-themes",
        "github.vscode-github-actions",
        "hashicorp.terraform",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "redhat.vscode-yaml"
      ]
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "silent"
  }
}